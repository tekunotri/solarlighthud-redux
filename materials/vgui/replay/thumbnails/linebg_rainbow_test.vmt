"UnlitGeneric"
{
	"$basetexture" "vgui/replay/thumbnails/linebg"
	"$vertexcolor" 1
	"$no_fullbright" 1
	"$ignorez" 1
	"%keywords" "tf"
	"$translucent" 1

    // The base texture will be multiplied by this color
    "$color" "[1.0 1.0 1.0]"

    "$offset" "0"
		
	"Proxies"
	{
		"TextureScroll"
		{	
			"texturescrollvar" "$baseTextureTransform"
			"texturescrollrate" 0.01
			"texturescrollangle" 90
		}
		
        "EntityRandom"
        {
            "scale" "12"
            "resultVar" "$offset"
        }
        "Sine"
        {
            "sineperiod" 4
            "timeoffset" "$offset"
            "resultVar" "$color[0]"
        }
        "Sine"
        {
            "sineperiod" 8
            "timeoffset" "$offset"
            "resultVar" "$color[1]"
        }
        "Sine"
        {
            "sineperiod" 12
            "timeoffset" "$offset"
            "resultVar" "$color[2]"
        }
	}
}

