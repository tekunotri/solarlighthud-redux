"UnlitGeneric"
{
	"$basetexture" "vgui/replay/thumbnails/linebg_tandarker_bigger_overlay"
	"$vertexcolor" 1
	"$no_fullbright" 1
	"$ignorez" 1
	"%keywords" "tf"
	"$translucent" 1

	"Proxies"
	{
		"TextureScroll"
		{	
			"texturescrollvar" "$baseTextureTransform"
			"texturescrollrate" 0.01
			"texturescrollangle" 90
		}
	}
}

