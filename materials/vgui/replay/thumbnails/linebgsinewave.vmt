"Refract"
{

	<dx90
	{
		 	"$fallbackmaterial" "vgui/replay/thumbnails/linebg"
	}

	"%keywords" "tf"
	"$refractamount" ".05"
	"$refracttint" "{255 225 255}"
	"$refractblur" "1"
	"$basetexture"	"vgui/replay/thumbnails/linebg"


	"$scale" "[1 1]"

	"$bumpmap" "dev/water_dudv"
	"$normalmap" "water/tfwater001_normal"
	"$bumpframe" "0"


	"Proxies"
	{
		"TextureScroll" //scroll the line BG (not working)
		{	
			"texturescrollvar" "$baseTextureTransform"
			"texturescrollrate" 0.01
			"texturescrollangle" 90
		}

		"AnimatedTexture" //animate the normal map
		{
			"animatedtexturevar" "$normalmap"
			"animatedtextureframenumvar" "$bumpframe"
			"animatedtextureframerate" 10.00 //slowed down, but it's choppy, sad
		}
		"TextureScroll" //scroll the water warping very fast
		{
			"texturescrollvar" "$bumptransform"
			"texturescrollrate" .01
			"texturescrollangle" 45.00
		}
	}
}

