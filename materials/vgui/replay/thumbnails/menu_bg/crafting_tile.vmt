"UnlitGeneric"
{
	"$basetexture" "vgui/replay/thumbnails/menu_bg/crafting_tile"
	"$vertexcolor" 1
	"$vertexalpha" 1
	"$no_fullbright" 1
	"$ignorez" 1
	"%keywords" "tf"
	"$translucent" 1

	"Proxies"
	{
		"TextureScroll"
		{	
			"texturescrollvar" "$baseTextureTransform"
			"texturescrollrate" 0.3
			"texturescrollangle" 235
		}
	}
}

