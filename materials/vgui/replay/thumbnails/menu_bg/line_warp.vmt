"UnlitGeneric"
{
	"$basetexture" "vgui/replay/thumbnails/menu_bg/line_warp"
	"$vertexcolor" 1
	"$no_fullbright" 1
	"$ignorez" 1
	"%keywords" "tf"
	"$translucent" 1

	"Proxies"
	{
		"AnimatedTexture"
		{
			"animatedTextureVar" "$basetexture"
			"animatedTextureFrameNumVar" "$frame"
			"animatedTextureFrameRate" "60"
		}

		"TextureScroll"
		{	
			"texturescrollvar" "$baseTextureTransform"
			"texturescrollrate" 0.2
			"texturescrollangle" 5
		}
	}

}

